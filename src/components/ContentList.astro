---
import ContentItem from "./ContentItem.astro";

const { posts } = Astro.props;
---

<ul class="contentlist">
  {
    posts.map((post) => (
      <li>
        <ContentItem post={post} />
      </li>
    ))
  }
</ul>

<style>
  .contentlist {
    list-style: none;
    padding: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: start;
  }

  li {
    width: 100%;
  }
</style>
