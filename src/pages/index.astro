---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import ContentList from "../components/ContentList.astro";
import TagList from "../components/TagList.astro";

const posts = await getCollection("writing");

posts.sort((a, b) => {
  return new Date(b.data.date) - new Date(a.data.date);
});

const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

const new_posts = posts.filter((post) => {return ( post.data.status == "new" ) && !(post.data.tags.includes("draft"))})
const growing_posts = posts.filter((post) => {return ( post.data.status == "growing" ) && !(post.data.tags.includes("draft"))})
const bloom_posts = posts.filter((post) => {return ( post.data.status == "bloom" ) && !(post.data.tags.includes("draft"))})
---

<Layout>
  <h1>agarden</h1>
  <div id="tag-filter">
    See writing on:
    <TagList tags={tags} />
  </div>
  { 
    bloom_posts.length == 0 ? "" :
      <h2>In Bloom</h2>
      <ContentList posts={bloom_posts} />
  }

  { 
    growing_posts.length == 0 ? "" :
      <h2>Growing</h2>
      <ContentList posts={growing_posts} />
  }

  { 
    new_posts.length == 0 ? "" :
      <h2>Newly Planted</h2>
      <ContentList posts={new_posts} />
  }

  <a href="/compost">the compost heap</a>
</Layout>

<style>
  #tag-filter {
    margin-block-end: 1rem;
  }
</style>
